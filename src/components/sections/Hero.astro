---
---

<section
  id="hero"
  class="min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16 relative overflow-hidden"
>
  <!-- Fondo decorativo -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-indigo-500/10 dark:bg-indigo-500/5 rounded-full blur-3xl" />
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <!-- Etiqueta -->
    <div
      id="hero-badge"
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-neutral-200 dark:border-neutral-800 text-sm text-neutral-500 dark:text-neutral-400 mb-8 opacity-0"
    >
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
      Disponible para proyectos
    </div>

    <!-- Título -->
    <h1
      id="hero-title"
      class="text-5xl md:text-7xl lg:text-8xl font-display font-extrabold leading-none tracking-tight mb-6 opacity-0"
    >
      Hola, soy
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-purple-600">
        Ale
      </span>
    </h1>

    <!-- Subtítulo -->
    <p
      id="hero-subtitle"
      class="text-lg md:text-xl text-neutral-500 dark:text-neutral-400 max-w-2xl mx-auto mb-10 leading-relaxed opacity-0"
    >
      Desarrollador web full-stack que convierte ideas en experiencias digitales
      rápidas, accesibles y con diseño profesional.
    </p>

    <!-- CTAs -->
    <div id="hero-cta" class="flex flex-wrap items-center justify-center gap-4 opacity-0">
      <a
        href="#projects"
        class="px-7 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full font-medium transition-all duration-200 hover:scale-105 active:scale-95 shadow-lg shadow-indigo-500/25"
      >
        Ver proyectos
      </a>
      <a
        href="#contact"
        class="px-7 py-3 border border-neutral-200 dark:border-neutral-700 hover:border-indigo-500 dark:hover:border-indigo-500 rounded-full font-medium transition-all duration-200 hover:scale-105 active:scale-95"
      >
        Contactar
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-neutral-400 dark:text-neutral-600">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-neutral-400 to-transparent dark:from-neutral-600 animate-bounce" />
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.to('#hero-badge', { opacity: 1, y: 0, duration: 0.6, delay: 0.2 })
    .to('#hero-title', { opacity: 1, y: 0, duration: 0.7 }, '-=0.3')
    .to('#hero-subtitle', { opacity: 1, y: 0, duration: 0.6 }, '-=0.4')
    .to('#hero-cta', { opacity: 1, y: 0, duration: 0.6 }, '-=0.4');

  // Estado inicial
  gsap.set(['#hero-badge', '#hero-title', '#hero-subtitle', '#hero-cta'], { y: 30 });
</script>
