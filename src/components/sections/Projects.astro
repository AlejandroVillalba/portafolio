---
const projects = [
  {
    title: 'Proyecto Alpha',
    description: 'Aplicación web full-stack con autenticación, dashboard en tiempo real y API REST. Construida con Next.js, PostgreSQL y Tailwind.',
    tags: ['Next.js', 'TypeScript', 'PostgreSQL', 'Tailwind'],
    link: '#',
    repo: '#',
    featured: true,
  },
  {
    title: 'Proyecto Beta',
    description: 'Plataforma de e-commerce con carrito de compras, pagos con Stripe y panel de administración.',
    tags: ['React', 'Node.js', 'Stripe', 'MongoDB'],
    link: '#',
    repo: '#',
    featured: false,
  },
  {
    title: 'Proyecto Gamma',
    description: 'CLI tool open source para automatizar tareas de desarrollo. Más de 500 estrellas en GitHub.',
    tags: ['Node.js', 'TypeScript', 'CLI'],
    link: '#',
    repo: '#',
    featured: false,
  },
];
---

<section id="projects" class="py-24 px-6 bg-neutral-50/50 dark:bg-neutral-900/30">
  <div class="max-w-6xl mx-auto">

    <div class="projects-header mb-16">
      <p class="text-sm font-medium text-indigo-500 uppercase tracking-widest mb-3">Trabajo</p>
      <h2 class="text-4xl md:text-5xl font-display font-bold">Proyectos seleccionados</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <article
          class={`project-card group relative p-6 rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 hover:border-indigo-400 dark:hover:border-indigo-500 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-500/10 ${project.featured ? 'md:col-span-2 lg:col-span-1' : ''}`}
          style={`--delay: ${i * 0.1}s`}
        >
          {project.featured && (
            <span class="absolute top-4 right-4 text-xs font-medium px-2.5 py-1 rounded-full bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-500/20">
              Destacado
            </span>
          )}

          <h3 class="text-lg font-bold mb-2 group-hover:text-indigo-500 transition-colors">
            {project.title}
          </h3>

          <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed mb-5">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-1.5 mb-5">
            {project.tags.map((tag) => (
              <span class="text-xs px-2.5 py-1 rounded-md bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex items-center gap-4 mt-auto pt-4 border-t border-neutral-100 dark:border-neutral-800">
            <a href={project.link} target="_blank" rel="noopener"
              class="text-sm font-medium text-indigo-500 hover:text-indigo-600 flex items-center gap-1 transition-colors">
              Demo
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </a>
            <a href={project.repo} target="_blank" rel="noopener"
              class="text-sm font-medium text-neutral-500 hover:text-neutral-800 dark:hover:text-neutral-200 flex items-center gap-1 transition-colors">
              Código
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.projects-header', {
    scrollTrigger: { trigger: '#projects', start: 'top 80%' },
    opacity: 0, y: 40, duration: 0.7, ease: 'power3.out',
  });

  gsap.from('.project-card', {
    scrollTrigger: { trigger: '.project-card', start: 'top 85%' },
    opacity: 0, y: 50, duration: 0.6, ease: 'power3.out',
    stagger: 0.12,
  });
</script>
