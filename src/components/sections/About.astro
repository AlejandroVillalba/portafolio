---
const skills = [
  'TypeScript', 'React', 'Next.js', 'Astro', 'Node.js',
  'Tailwind CSS', 'PostgreSQL', 'Docker', 'Git',
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Encabezado de sección -->
    <div class="section-header mb-16">
      <p class="text-sm font-medium text-indigo-500 uppercase tracking-widest mb-3">Sobre mí</p>
      <h2 class="text-4xl md:text-5xl font-display font-bold">
        Un poco de mí
      </h2>
    </div>

    <!-- Grid 2 columnas -->
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Texto -->
      <div class="about-content space-y-5 text-neutral-600 dark:text-neutral-400 leading-relaxed text-[1.05rem]">
        <p>
          Soy desarrollador web con pasión por construir productos digitales que hacen la diferencia.
          Me especializo en el desarrollo full-stack, con énfasis en interfaces rápidas y experiencias de usuario memorables.
        </p>
        <p>
          Cuando no estoy codificando, me encuentro explorando nuevas tecnologías, contribuyendo a proyectos open source,
          o leyendo sobre diseño moderno.
        </p>
        <a
          href="/cv.pdf"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-indigo-500 hover:text-indigo-600 font-medium transition-colors group"
        >
          Descargar CV
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" x2="12" y1="15" y2="3"/>
          </svg>
        </a>
      </div>

      <!-- Skills -->
      <div class="about-skills">
        <p class="text-sm font-medium text-neutral-500 dark:text-neutral-400 mb-5 uppercase tracking-widest">Stack & herramientas</p>
        <div class="flex flex-wrap gap-2.5">
          {skills.map((skill) => (
            <span class="skill-tag px-4 py-2 text-sm font-medium rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 hover:border-indigo-500 hover:text-indigo-500 transition-colors cursor-default">
              {skill}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.section-header', {
    scrollTrigger: { trigger: '#about', start: 'top 80%' },
    opacity: 0, y: 40, duration: 0.7, ease: 'power3.out',
  });

  gsap.from('.about-content', {
    scrollTrigger: { trigger: '#about', start: 'top 70%' },
    opacity: 0, x: -40, duration: 0.8, ease: 'power3.out', delay: 0.2,
  });

  gsap.from('.about-skills', {
    scrollTrigger: { trigger: '#about', start: 'top 70%' },
    opacity: 0, x: 40, duration: 0.8, ease: 'power3.out', delay: 0.2,
  });

  gsap.from('.skill-tag', {
    scrollTrigger: { trigger: '.about-skills', start: 'top 80%' },
    opacity: 0, scale: 0.8, duration: 0.4, ease: 'back.out(1.7)',
    stagger: 0.05, delay: 0.3,
  });
</script>
